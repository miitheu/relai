# Relai CRM Configuration
# ========================

# Mode: 'hosted' (Supabase) or 'self-hosted' (own Postgres + API server)
VITE_CRM_MODE=hosted

# ---- Hosted mode (Supabase) ----
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ---- Self-hosted mode ----
# VITE_CRM_MODE=self-hosted
# VITE_API_URL=http://localhost:3001

# API Server (self-hosted only)
# DATABASE_URL=postgres://user:pass@localhost:5432/relai
# AUTH_SECRET=your-jwt-secret-min-32-chars
# API_PORT=3001
# CORS_ORIGIN=http://localhost:8080
# STORAGE_DIR=./uploads
